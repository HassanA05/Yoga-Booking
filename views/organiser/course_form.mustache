{{> head}}
{{> header}}

<div class="page-title-row">
  <h1>{{title}}</h1>
  <a class="btn" href="/organiser/courses">Back to Courses</a>
</div>

<form method="post" action="{{action}}" class="form-card">
  <div class="field">
    <label for="title">Course Title <span class="required">*</span></label>
    <input id="title" name="title" type="text" required value="{{course.title}}" placeholder="e.g. Morning Vinyasa Flow" />
  </div>

  <div class="field">
    <label for="level">Level <span class="required">*</span></label>
    <select id="level" name="level" required>
      <option value="">Select level</option>
      <option value="beginner" {{#course.isLevelBeginner}}selected{{/course.isLevelBeginner}}>Beginner</option>
      <option value="intermediate" {{#course.isLevelIntermediate}}selected{{/course.isLevelIntermediate}}>Intermediate</option>
      <option value="advanced" {{#course.isLevelAdvanced}}selected{{/course.isLevelAdvanced}}>Advanced</option>
    </select>
  </div>

  <div class="field">
    <label for="type">Type <span class="required">*</span></label>
    <select id="type" name="type" required>
      <option value="">Select type</option>
      <option value="WEEKLY_BLOCK" {{#course.isTypeWeekly}}selected{{/course.isTypeWeekly}}>Weekly Block</option>
      <option value="WEEKEND_WORKSHOP" {{#course.isTypeWeekend}}selected{{/course.isTypeWeekend}}>Weekend Workshop</option>
    </select>
  </div>

  <div class="field checkbox">
    <input id="allowDropIn" name="allowDropIn" type="checkbox" value="on" {{#course.allowDropIn}}checked{{/course.allowDropIn}} />
    <label for="allowDropIn">Allow drop-in bookings for individual sessions</label>
  </div>

  <div class="field">
    <label for="startDate">Start Date</label>
    <input id="startDate" name="startDate" type="date" value="{{course.startDate}}" />
  </div>

  <div class="field">
    <label for="endDate">End Date</label>
    <input id="endDate" name="endDate" type="date" value="{{course.endDate}}" />
  </div>

  <div class="field">
    <label for="location">Location</label>
    <input id="location" name="location" type="text" value="{{course.location}}" placeholder="e.g. Studio 1, Glasgow" />
  </div>

  <div class="field">
    <label for="price">Price per course (&pound;)</label>
    <input id="price" name="price" type="number" min="0" step="0.01" value="{{course.price}}" placeholder="e.g. 80.00" />
  </div>

  <div class="field">
    <label for="description">Description</label>
    <textarea id="description" name="description" rows="4" placeholder="Describe the course...">{{course.description}}</textarea>
  </div>

  <div class="actions">
    <button class="btn primary" type="submit">{{buttonLabel}}</button>
    <a class="btn" href="/organiser/courses">Cancel</a>
  </div>
</form>

{{> footer}}
