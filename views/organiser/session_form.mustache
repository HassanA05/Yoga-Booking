{{> head}}
{{> header}}

<div class="page-title-row">
  <h1>{{title}}</h1>
  <a class="btn" href="/organiser/courses/{{course.id}}/sessions">Back to Sessions</a>
</div>

{{#error}}<div class="alert error" role="alert">{{error}}</div>{{/error}}

<form method="post" action="{{action}}" class="form-card">
  <div class="field">
    <label for="startDateTime">Start Date &amp; Time <span class="required">*</span></label>
    <input id="startDateTime" name="startDateTime" type="datetime-local" required value="{{session.startDateTime}}" />
  </div>

  <div class="field">
    <label for="endDateTime">End Date &amp; Time <span class="required">*</span></label>
    <input id="endDateTime" name="endDateTime" type="datetime-local" required value="{{session.endDateTime}}" />
  </div>

  <div class="field">
    <label for="capacity">Capacity <span class="required">*</span></label>
    <input id="capacity" name="capacity" type="number" required min="1" max="200" value="{{session.capacity}}" placeholder="e.g. 20" />
  </div>

  <div class="actions">
    <button class="btn primary" type="submit">{{buttonLabel}}</button>
    <a class="btn" href="/organiser/courses/{{course.id}}/sessions">Cancel</a>
  </div>
</form>

{{> footer}}
