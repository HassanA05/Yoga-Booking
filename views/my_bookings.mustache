{{> head}}
{{> header}}

<h1>My Bookings</h1>

{{#bookings}}
<table class="table">
  <thead>
    <tr>
      <th>Course</th>
      <th>Type</th>
      <th>Status</th>
      <th>Booked At</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    {{#bookings}}
    <tr>
      <td><a href="/courses/{{courseId}}">{{courseTitle}}</a></td>
      <td>{{type}}</td>
      <td><span class="badge">{{status}}</span></td>
      <td>{{createdAt}}</td>
      <td><a class="btn" href="/courses/{{courseId}}">View Course</a></td>
    </tr>
    {{/bookings}}
  </tbody>
</table>
{{/bookings}}

{{^bookings}}
<p>You have no bookings yet. <a href="/courses">Browse courses</a> to get started.</p>
{{/bookings}}

{{> footer}}
